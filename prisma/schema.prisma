generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
//  CORE: Users & Auth
// ═══════════════════════════════════════

model User {
  id             String     @id @default(cuid())
  email          String?    @unique
  wechatId       String?    @unique
  name           String
  avatar         String?
  role           String     @default("support")
  shopId         String?
  pushSub        String?
  webauthnCred   String?
  emailVerified  DateTime?
  hashedPassword String?
  accounts       Account[]
  sessions       Session[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  auditLogs      AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════
//  CORE: Shop (multi-platform ready)
// ═══════════════════════════════════════

model Shop {
  id          String        @id @default(cuid())
  name        String
  platform    String        @default("tiktok")
  site        String
  shopId      String
  authData    String?       // JSON: platform auth tokens
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  products    Product[]
  orders      Order[]
  livestreams Livestream[]
  campaigns   Campaign[]
}

// ═══════════════════════════════════════
//  MODULE: Product
// ═══════════════════════════════════════

model Product {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  tiktokId    String?
  title       String
  description String?
  mainImage   String?
  images      String   @default("[]")
  categoryId  String?
  brand       String?
  price       Float    @default(0)
  costPrice   Float?
  stock       Int      @default(0)
  status      String   @default("draft")
  source      String?
  sourceUrl   String?
  skus        Sku[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sku {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  skuCode    String
  price      Float   @default(0)
  stock      Int     @default(0)
  attributes String  @default("{}") // JSON

  @@unique([productId, skuCode])
}

// ═══════════════════════════════════════
//  MODULE: Order
// ═══════════════════════════════════════

model Order {
  id           String     @id @default(cuid())
  shopId       String
  shop         Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  tiktokId     String     @unique
  status       String     @default("unpaid")
  buyerName    String?
  buyerPhone   String?
  shippingAddr String?
  items        OrderItem[]
  totalAmount  Float      @default(0)
  currency     String     @default("USD")
  paidAt       DateTime?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  skuName   String
  skuCode   String
  quantity  Int    @default(1)
  price     Float  @default(0)
}

// ═══════════════════════════════════════
//  MODULE: Purchase & Supplier
// ═══════════════════════════════════════

model Supplier {
  id        String           @id @default(cuid())
  name      String
  platform  String           @default("1688")
  storeUrl  String?
  contact   String?
  rating    Int              @default(3)
  notes     String?
  products  SupplierProduct[]
  createdAt DateTime         @default(now())
}

model SupplierProduct {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId   String
  sourceUrl   String
  unitPrice   Float    @default(0)
  minOrder    Int      @default(1)
  shippingFee Float?
  lastUpdated DateTime @default(now())
}

model PurchaseOrder {
  id          String         @id @default(cuid())
  supplierId  String?
  supplierUrl String?
  items       PurchaseItem[]
  status      String         @default("pending")
  totalAmount Float?
  createdAt   DateTime       @default(now())
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  skuName         String
  quantity        Int           @default(1)
  unitPrice       Float         @default(0)
  sourceUrl       String?
}

// ═══════════════════════════════════════
//  MODULE: Warehouse & Stock
// ═══════════════════════════════════════

model Warehouse {
  id   String @id @default(cuid())
  name String
  type String @default("self")
}

model Stock {
  id          String   @id @default(cuid())
  warehouseId String
  productId   String
  skuCode     String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([warehouseId, productId, skuCode])
}

// ═══════════════════════════════════════
//  MODULE: Finance
// ═══════════════════════════════════════

model FinanceRecord {
  id        String   @id @default(cuid())
  shopId    String
  type      String
  amount    Float
  currency  String   @default("USD")
  orderId   String?
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════
//  MODULE: Livestream
// ═══════════════════════════════════════

model Livestream {
  id          String               @id @default(cuid())
  shopId      String
  shop        Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  title       String
  status      String               @default("scheduled")
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  products    LivestreamProduct[]
  metrics     LivestreamMetrics?
  createdAt   DateTime             @default(now())
}

model LivestreamProduct {
  id           String     @id @default(cuid())
  livestreamId String
  livestream   Livestream @relation(fields: [livestreamId], references: [id], onDelete: Cascade)
  productId    String
  sortOrder    Int        @default(0)
  explained    Boolean    @default(false)
  soldCount    Int        @default(0)
  gmv          Float      @default(0)
}

model LivestreamMetrics {
  id           String     @id @default(cuid())
  livestreamId String     @unique
  livestream   Livestream @relation(fields: [livestreamId], references: [id], onDelete: Cascade)
  peakViewers  Int        @default(0)
  totalViewers Int        @default(0)
  totalOrders  Int        @default(0)
  totalGmv     Float      @default(0)
  avgStayTime  Float?
  newFollowers Int        @default(0)
}

model LivestreamScript {
  id        String @id @default(cuid())
  productId String
  content   String
  type      String
}

// ═══════════════════════════════════════
//  MODULE: Influencer
// ═══════════════════════════════════════

model Influencer {
  id          String     @id @default(cuid())
  name        String
  tiktokId    String?
  followers   Int?
  avgViews    Int?
  category    String?
  contactInfo String?
  status      String     @default("new")
  notes       String?
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
}

model Campaign {
  id           String     @id @default(cuid())
  shopId       String
  shop         Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  productId    String?
  type         String     @default("affiliate")
  status       String     @default("pending")
  commission   Float?
  sampleSent   Boolean    @default(false)
  gmv          Float      @default(0)
  ordersCount  Int        @default(0)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime   @default(now())
}

// ═══════════════════════════════════════
//  MODULE: AI Video
// ═══════════════════════════════════════

model AiVideo {
  id           String   @id @default(cuid())
  productId    String
  title        String
  script       String?
  videoUrl     String?
  thumbnailUrl String?
  status       String   @default("pending")
  platform     String   @default("tiktok")
  publishUrl   String?
  views        Int      @default(0)
  gmv          Float    @default(0)
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════
//  MODULE: Selection & Competitor
// ═══════════════════════════════════════

model SelectionProduct {
  id           String   @id @default(cuid())
  source       String
  sourceName   String?
  title        String
  image        String?
  price        Float    @default(0)
  sales        Int?
  growth       Float?
  category     String?
  sourceUrl    String?
  supplierUrl  String?
  profitMargin Float?
  createdAt    DateTime @default(now())
}

model SelectionChannel {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   @default("hot_list")
  isBuiltin Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Competitor {
  id        String             @id @default(cuid())
  name      String
  shopUrl   String
  platform  String             @default("tiktok")
  products  CompetitorProduct[]
  createdAt DateTime           @default(now())
}

model CompetitorProduct {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  title        String
  price        Float      @default(0)
  sales        Int?
  image        String?
  sourceUrl    String?
  lastChecked  DateTime   @default(now())
  createdAt    DateTime   @default(now())
}

model PriceAlert {
  id        String   @id @default(cuid())
  productId String
  oldPrice  Float
  newPrice  Float
  changePct Float
  alertType String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════
//  MODULE: CRM
// ═══════════════════════════════════════

model Customer {
  id            String    @id @default(cuid())
  shopId        String
  name          String?
  email         String?
  phone         String?
  region        String?
  totalOrders   Int       @default(0)
  totalSpent    Float     @default(0)
  avgOrderValue Float?
  tags          String    @default("[]")
  segment       String    @default("active")
  firstOrderAt  DateTime?
  lastOrderAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ═══════════════════════════════════════
//  MODULE: Logistics
// ═══════════════════════════════════════

model LogisticsProvider {
  id        String         @id @default(cuid())
  name      String
  apiKey    String?
  regions   String         @default("[]")
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
}

model ShippingRate {
  id           String            @id @default(cuid())
  providerId   String
  provider     LogisticsProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  originRegion String
  destRegion   String
  weightRange  String
  price        Float
  eta          Int
}

// ═══════════════════════════════════════
//  MODULE: Automation & AI
// ═══════════════════════════════════════

model AutomationRule {
  id        String           @id @default(cuid())
  name      String
  trigger   String
  action    String
  config    String           @default("{}")
  enabled   Boolean          @default(true)
  useAI     Boolean          @default(false)
  logs      AutomationLog[]
  createdAt DateTime         @default(now())
}

model AutomationLog {
  id        String          @id @default(cuid())
  ruleId    String?
  rule      AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  trigger   String
  action    String
  decision  String?
  executed  Boolean         @default(false)
  result    String?
  createdAt DateTime        @default(now())
}

// ═══════════════════════════════════════
//  MODULE: Webhook & Audit
// ═══════════════════════════════════════

model WebhookEvent {
  id        String   @id @default(cuid())
  source    String
  eventType String
  payload   String   @default("{}")
  status    String   @default("pending")
  error     String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  resource   String
  resourceId String?
  detail     String?
  ip         String?
  createdAt  DateTime @default(now())
}

// ═══════════════════════════════════════
//  CORE: Custom Fields (EAV)
// ═══════════════════════════════════════

model CustomField {
  id        String   @id @default(cuid())
  entity    String
  fieldName String
  fieldType String
  label     String
  options   String?
  required  Boolean  @default(false)
  order     Int      @default(100)
  createdAt DateTime @default(now())

  @@unique([entity, fieldName])
}

model CustomFieldValue {
  id       String @id @default(cuid())
  entityId String
  fieldId  String
  value    String

  @@unique([entityId, fieldId])
}
